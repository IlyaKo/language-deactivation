<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Language deactivation"
        Background="#F3F4F6"
        MinWidth="450"
        MinHeight="250">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Window.Styles>
        <Style Selector="Button.LanguageCard">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.LanguageCard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>
        
        <Style Selector="Button.LanguageCard:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E5E7EB"/>
        </Style>
    </Window.Styles>

<ScrollViewer Padding="16">
        <ItemsControl ItemsSource="{Binding Languages}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    
                    <Border CornerRadius="8" Background="White" Margin="0,0,0,12" BoxShadow="0 2 6 0 #10000000">
                        
                        <Button Classes="LanguageCard" 
                                Command="{Binding ToggleCommand}"
                                IsEnabled="{Binding !IsUserInterface}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                        Background="#EBF1FA" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ShortCode}" Foreground="#1E5EDB" 
                                               FontSize="14" FontWeight="Bold" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Foreground="#111827"/>
                                    <TextBlock Text="{Binding Tag}" FontSize="13" Foreground="#6B7280" Margin="0,2,0,0"/>
                                    
                                    <TextBlock Text="System UI language (cannot be disabled)" 
                                               FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"
                                               IsVisible="{Binding IsUserInterface}"/>
                                </StackPanel>
                                
                                <ToggleSwitch Grid.Column="2" 
                                              IsChecked="{Binding Enabled}" 
                                              IsEnabled="{Binding !IsUserInterface}"
                                              IsHitTestVisible="False"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        
                    </Border>
                    
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

</Window>
